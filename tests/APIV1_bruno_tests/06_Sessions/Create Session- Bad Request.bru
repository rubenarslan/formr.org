meta {
  name: Create Session: Bad Request
  type: http
  seq: 5
}

post {
  url: {{host}}/v1/runs/api-test/sessions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "code": [
      "ShortCode",
      "Bad&Character&Code"
    ],
    "testing": 0
  }
}

assert {
  res.status: eq 400
}

script:post-response {
  var code = null;
    
    if (res.body.code) {
      code = res.body.code;
    } else if (res.body.sessions && res.body.sessions.length > 0) {
      code = res.body.sessions[0];
    }
  
    if (code) {
      bru.setVar("session_code", code);
      console.log("✅ Session captured: " + code);
    } else {
      console.log("⚠️ No session code found in response");
    }
}

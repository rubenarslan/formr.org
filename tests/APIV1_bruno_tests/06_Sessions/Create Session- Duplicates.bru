meta {
  name: Create Session: Duplicates
  type: http
  seq: 3
}

post {
  url: {{host}}/v1/runs/api-test/sessions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "code": [
      "TestUser_Alpha_0000000000000000000000000000000000000000000000001",
      "TestUser_Delta_0000000000000000000000000000000000000000000000001"
    ],
    "testing": 0
  }
}

assert {
  res.body.count_created: eq 1
  res.body.count_failed: eq 1
  res.body.errors[0].reason: eq Session already exists.
}

script:post-response {
  var code = null;
    
    if (res.body.code) {
      code = res.body.code;
    } else if (res.body.sessions && res.body.sessions.length > 0) {
      code = res.body.sessions[0];
    }
  
    if (code) {
      bru.setVar("session_code", code);
      console.log("✅ Session captured: " + code);
    } else {
      console.log("⚠️ No session code found in response");
    }
}

meta {
  name: Create Survey from XLSX
  type: http
  seq: 1
}

post {
  url: {{host}}/v1/surveys/
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  file: @file(assets/survey.xlsx)
}

assert {
  res.status: eq 200
  res.body.name: eq survey
}

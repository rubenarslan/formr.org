meta {
  name: Create Survey from XLSX
  type: http
  seq: 1
}

post {
  url: {{host}}/v1/surveys/api_test_survey
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  file: @file(assets/survey.xlsx)
}

assert {
  res.status: eq 201
  res.body.name: eq api_test_survey
}
